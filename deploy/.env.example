# Apex Django — production env file.
#
# Copy to /etc/apex-django.env on the server (referenced by the systemd
# unit's EnvironmentFile=). chmod 0640 + chown apex:apex.
#
# Don't commit the real file — this is the template only.

# Django settings module — uses the Postgres-aware prod settings.
DJANGO_SETTINGS_MODULE=apex.settings.prod

# Pinned to the demo domain by prod.py; add comma-separated extras here
# (e.g. for direct origin access during debugging).
ALLOWED_HOSTS=apex-django.dashboardpack.com

# Generate with:
#   uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-50-char-random-string

# Postgres — schema + user must exist:
#   sudo -u postgres createuser apex_django -P
#   sudo -u postgres createdb apex_django -O apex_django
DATABASE_URL=postgres://apex_django:CHANGE_ME@127.0.0.1:5432/apex_django

# Redis (optional). If set, the channel layer upgrades from in-memory
# to channels-redis, enabling realtime fan-out across multiple Daphne
# workers. For single-process demo traffic you can leave this empty.
# REDIS_URL=redis://127.0.0.1:6379/0

# Email (optional). Defaults to console backend; configure SMTP if you
# want password resets / invitations to actually deliver.
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=postmaster@example.com
# EMAIL_HOST_PASSWORD=...
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=Apex Demo <demo@dashboardpack.com>

# Demo mode — pre-fills login banner with demo / ApexShowcase!2026.
# Leave OFF in prod unless you actually want a public demo.
DEMO_MODE=true
