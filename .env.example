# Apex Dashboard — environment variables
# Copy to .env and edit. Required values are marked.

# === Required in production ===

# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(50))'
SECRET_KEY=replace-me-with-a-secret

# Comma-separated bare hostnames you serve from.
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL. SQLite (default in apex.settings.dev) is fine for local;
# Postgres or SQL Server in production.
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/apex
# DATABASE_URL=mssql://user:password@localhost:1433/apex
# DATABASE_URL=mssql://user:password@localhost:1433/apex?trust_server_certificate=yes
# (mssql:// requires `uv sync --extra mssql` and Microsoft ODBC Driver 18 installed.)

# === Recommended ===

# 'console' prints to stdout (dev). Switch to smtp.EmailBackend for real email.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@yourdomain.example

# SMTP relay (set when EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True

# === Optional ===

# 'False' in production unless actively debugging
DEBUG=True

# Django settings module — apex.settings.dev or apex.settings.prod
# DJANGO_SETTINGS_MODULE=apex.settings.prod
